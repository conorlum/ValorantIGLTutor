const script = document.currentScript;

window.trackerads= {
    version: '1.0.3.1',
    primisId: script.dataset.primisId,
    primisMobileId: script.dataset.primisMobileId,
    disableCPMStartEvents: script.dataset.cpmstartEvents,
    mode: script.dataset.mode,
    cpmstarLoaded: false,
    videoLoaded: false,
    initializeExternalAdNetworks: function () {        
        var pathName = window.location.pathname

        if (pathName === '/') {
            return
        }

        var rnd = Math.random();
        if (rnd < 0.5) {
            initializeNitro();
        } else {
            initializePrimis();
        }
    }
};
function initializePrimis() {    
    var pathName = window.location.pathname

    if (!window.trackerads.primisId) {
        return
    }
    if (!window.trackerads.videoLoaded) {
        window.trackerads.videoLoaded = true;

        var primisId = window.trackerads.primisId; 
        
        if (window.trackerads.primisMobileId && window.matchMedia("only screen and (max-width: 760px)").matches) {
            primisId = window.trackerads.primisMobileId;
            console.log("This is a mobile device1.");
            
            const script = document.createElement('script')
            script.src = 'https://live.primis.tech/live/liveView.php?s=' + primisId
            script.type = 'text/javascript'    
            document.body.prepend(script)

         } else {
            const script = document.createElement('script')
            script.src = 'https://live.primis.tech/live/liveView.php?s=' + primisId
            script.type = 'text/javascript'    
    
            document.body.appendChild(script)
         }
    }    
}

function initializeNitro() { 
    if (!window.trackerads.videoLoaded) { 
        window.trackerads.videoLoaded = true;

        window['nitroAds'].createAd('nitro-video', {
            "format": "floating",
            "onNavigateMin": 10000,
            "report": {
                "enabled": true,
                "icon": true,
                "wording": "Report Ad",
                "position": "top-left-side"
            }
        });

        const urlParams = new URLSearchParams(window.location.search);

        if (urlParams.has('trndebug')) {
            window['nitroAds'].createAd('anchor-1', {
                "refreshTime": 30,
                "format": "anchor-v2",
                "anchor": "top",
                "anchorPersistClose": true,
                "anchorBgColor": "rgb(0, 0, 0, .9)",
                "report": {
                    "enabled": true,
                    "icon": true,
                    "wording": "Report Ad",
                    "position": "top-right"
                },
                targeting: {
                    titleSlug: 'fortnite',
                    featureSet: typeof trn_feature_set !== 'undefined' ? trn_feature_set : 'unset',
                    analyticsUrl: typeof ga_url_override !== 'undefined' ? ga_url_override : 'unset'
                },
                "mediaQuery": "(min-width: 320px) and (max-width: 767px)"
            });
        }
    }    
}

if (window.trackerads.mode !== 'spa') {
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', window.trackerads.initializeExternalAdNetworks());
    } else {
        window.trackerads.initializeExternalAdNetworks();
    }
}